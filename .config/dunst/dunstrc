[global]
    ### Display ###
    monitor = 0
    follow = mouse
    width = 300
    height = 200
    origin = top-right
    offset = 10x40
    scale = 0
    notification_limit = 5

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 2
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    ### Text ###
    font = Monospace 10
    line_height = 0
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    stack_duplicates = true

    ### Frame ###
    frame_width = 2
    frame_color = "#333333"
    separator_color = frame
    corner_radius = 10

    ### Legacy/Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#111314"
    foreground = "#888888"
    timeout = 5

[urgency_normal]
    background = "#111314"
    foreground = "#ffffff"
    timeout = 10

[urgency_critical]
    background = "#111314"
    foreground = "#ff5555"
    frame_color = "#ff5555"
    timeout = 0
